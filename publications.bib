@article{banack2018,
  ids = {banack2018a},
  title = {Accounting for {{Selection Bias}} in {{Studies}} of {{Acute Cardiac Events}}},
  author = {Banack, Hailey R. and Harper, Sam and Kaufman, Jay S.},
  year = 2018,
  month = jun,
  journal = {Canadian Journal of Cardiology},
  volume = {34},
  number = {6},
  pages = {709--716},
  issn = {0828282X},
  doi = {10.1016/j.cjca.2018.01.013},
  urldate = {2021-11-02},
  abstract = {Background: In cardiovascular research, pre-hospital mortality represents an important potential source of selection bias. Inverse probability of censoring weights are a method to account for this source of bias. The objective of this article is to examine and correct for the influence of selection bias due to pre-hospital mortality on the relationship between cardiovascular risk factors and all-cause mortality after an acute cardiac event.},
  copyright = {All rights reserved},
